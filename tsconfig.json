{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ES5",
		"types": [],
		// For nodejs:
		"lib": [
			"dom",
			"dom.iterable",
			"esnext",
			"ES6",
		],
		// Recommended Options
		"strict": true,
		"jsx": "react-jsx",
		"esModuleInterop": true,
		"isolatedModules": true,
		"moduleResolution": "node",
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"baseUrl": ".",
		"paths": {
			"*": [
				"src/*"
			]
		}
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"node_modules",
		"dist"
	],
}